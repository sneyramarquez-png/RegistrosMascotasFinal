<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AccessActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <TextView
            android:text="Acceso a su cuenta 🐾"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#7DCFB6"
            android:textColor="#F79256"
            />

    <EditText
        android:id="@+id/correo_acceder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/campoCorreoAcceder"

        />
    <EditText
        android:id="@+id/contrasena_acceder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/campoContrasenaAcceder"
        />
    <Button
        android:id="@+id/btn_acceder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_ingresar"
        android:backgroundTint="#00B2CA"
        />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>