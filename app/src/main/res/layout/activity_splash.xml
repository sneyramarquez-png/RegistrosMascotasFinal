<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashActivity">
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/AnimationPrincipal"
        android:layout_width="300dp"
        android:layout_height="200dp"
        app:lottie_fileName="Pets.json"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

    <TextView
        android:id="@+id/TituloPrincipalInicio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/tituloPrincipal"
        android:textAlignment="center"
        android:textColor="#2196F3"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/AnimationPrincipal"
        />

    <TextView
        android:id="@+id/subtituloIntegrante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/Integrante1"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@+id/TituloPrincipalInicio"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/Integrante2"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@+id/subtituloIntegrante"
        />


</androidx.constraintlayout.widget.ConstraintLayout>